// Prisma schema for Vezeeta backend
// Better Auth owns the User, Session, Account, Verification tables.
// Doctor is a standalone CRUD record managed by admins (no relation to User).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// =================== Better Auth core tables ===================

model User {
  id                  String   @id @default(cuid())
  name                String
  email               String   @unique
  emailVerified       Boolean  @default(false)
  image               String?
  phoneNumber         String?  @unique
  phoneNumberVerified Boolean  @default(false)
  role                String   @default("user")
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  sessions       Session[]
  accounts       Account[]
  appointments   Appointment[]
  reviews        Review[]
  medicalRecords MedicalRecord[]
  notifications  Notification[]

  // Speeds up the last-admin guard and admin stats groupBy.
  @@index([role, isActive])
  @@index([isActive])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =================== Domain tables ===================

// Category is the controlled vocabulary doctors reference (feature
// 005-doctor-categories). It is admin-managed and public-readable
// (filtered to ACTIVE rows). Composite unique on (name, status) lets
// a DEACTIVATED row share a name with an ACTIVE row, so re-creation
// under a previously-retired name is possible.
model Category {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors Doctor[]

  @@unique([name, status])
  @@index([status])
  @@map("category")
}

// Doctor is a standalone CRUD record. It has NO foreign key to User.
// Doctors cannot log in; they are managed entirely by admins via the
// /api/admin/doctors endpoints (see feature 003-remove-doctor-role).
// categoryId is required and references an ACTIVE Category (feature
// 005-doctor-categories); the free-text `specialty` column was
// dropped in this migration.
model Doctor {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  bio        String?
  imageUrl   String?
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category       Category        @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  slots          DoctorSlot[]
  appointments   Appointment[]
  reviews        Review[]
  medicalRecords MedicalRecord[]

  @@index([status])
  @@index([categoryId])
  @@map("doctor")
}

// DoctorSlot is a bookable time window attached to a doctor
// (feature 006-appointments-booking). Lifecycle:
//   AVAILABLE -> BOOKED (patient booking, atomic with appointment create)
//   AVAILABLE -> BLOCKED (admin block, or PATCH status=BLOCKED)
//   BOOKED -> AVAILABLE (appointment cancellation, atomic with the
//     appointment update)
// One slot can result in at most one appointment (enforced by the
// UNIQUE constraint on Appointment.slotId).
model DoctorSlot {
  id        String   @id @default(cuid())
  doctorId  String
  startsAt  DateTime
  endsAt    DateTime
  status    String   @default("AVAILABLE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  appointment Appointment?

  @@index([doctorId, startsAt])
  @@index([status])
  @@map("doctor_slot")
}

// Appointment is a patient's claim on a doctor slot. Lifecycle:
//   PENDING (on booking) -> CONFIRMED (admin confirms)
//   PENDING -> CANCELLED (patient or admin cancels)
//   CONFIRMED -> CANCELLED (patient <= 24h cutoff, or admin any time)
//   CONFIRMED -> COMPLETED (admin completes, requires scheduledAt in
//     the past)
// Terminal states: COMPLETED and CANCELLED are immutable.
// UNIQUE on slotId enforces 1:1 with the slot at the DB level; the
// application's prisma.$transaction with a conditional updateMany is
// the application-level concurrency guard.
model Appointment {
  id           String    @id @default(cuid())
  userId       String
  doctorId     String
  slotId       String    @unique
  scheduledAt  DateTime
  status       String    @default("PENDING")
  patientNotes String?
  adminNotes   String?
  cancelledAt  DateTime?
  cancelledBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user          User           @relation(fields: [userId], references: [id], onDelete: Restrict)
  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  slot          DoctorSlot     @relation(fields: [slotId], references: [id], onDelete: Restrict)
  review        Review?
  medicalRecord MedicalRecord?

  @@index([userId, scheduledAt])
  @@index([doctorId, scheduledAt])
  @@index([status])
  // (userId|doctorId, status, scheduledAt) — covers the per-user and
  // per-doctor list-with-status-filter queries (the second composite
  // column on the existing indexes is `scheduledAt` which doesn't help
  // when an additional `status` filter is present).
  @@index([userId, status, scheduledAt])
  @@index([doctorId, status, scheduledAt])
  // (status, scheduledAt) — covers the reminder-cron scan that filters
  // by `status = 'CONFIRMED' AND scheduledAt BETWEEN ? AND ?`.
  @@index([status, scheduledAt])
  @@map("appointment")
}

// Review is a 1:1 relation with Appointment: a patient can leave
// exactly one review per COMPLETED appointment. Built-in module 04
// (reviews-ratings, plan.md §7). Rating is 1-5 (inclusive). The
// (appointmentId, doctorId) pair is denormalised from the appointment
// to support the public `/api/doctors/:id/reviews` listing without a
// join through appointment every read.
model Review {
  id            String      @id @default(cuid())
  appointmentId String      @unique
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  userId        String
  user          User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  doctorId      String
  doctor        Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  rating        Int
  comment       String?
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  @@index([doctorId, createdAt])
  @@index([userId])
  @@map("review")
}

// MedicalRecord is a 1:1 with Appointment: created by an admin (the
// platform acts on the treating doctor's behalf — see feature
// 003-remove-doctor-role: doctors are not users and cannot log in).
// Read access is restricted to the admin (acting as the treating
// doctor) and the patient who owns the appointment — constitution
// principle VI (Auth & Access Control) flags medical record access as
// a non-negotiable day-one constraint.
model MedicalRecord {
  id             String      @id @default(cuid())
  appointmentId  String      @unique
  appointment    Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  patientId      String
  patient        User        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId       String
  doctor         Doctor      @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  notes          String?
  attachmentUrls String[]
  createdById    String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([patientId])
  @@index([doctorId])
  @@map("medical_record")
}

// Notification is an in-app inbox row (channel-aware) optionally
// dispatched via email/SMS through the existing EmailService. Driven by
// domain events from other modules (constitution principle II —
// Domain-Event Decoupling): appointment.created/confirmed/cancelled/
// completed, review.posted, medical-record.created.
model Notification {
  id        String    @id @default(cuid())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel   String    @default("EMAIL")
  status    String    @default("QUEUED")
  title     String
  body      String
  metadata  Json?
  sentAt    DateTime?
  readAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([status])
  // GIN index on metadata is added in a follow-up migration because
  // Prisma's schema language does not yet support functional / GIN
  // indexes natively. The reminder cron uses
  // `metadata: { path: ['kind'], equals: 'appointment.reminder' }`
  // and benefits from `CREATE INDEX notification_metadata_gin
  // ON notification USING gin (metadata jsonb_path_ops);`.
  @@map("notification")
}

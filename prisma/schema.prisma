// Prisma schema for Vezeeta backend
// Better Auth owns the User, Session, Account, Verification tables.
// Doctor is a standalone CRUD record managed by admins (no relation to User).

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// =================== Better Auth core tables ===================

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  emailVerified       Boolean   @default(false)
  image               String?
  phoneNumber         String?   @unique
  phoneNumberVerified Boolean   @default(false)
  role                String    @default("user")
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  sessions Session[]
  accounts Account[]
  appointments Appointment[]

  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

// =================== Domain tables ===================

// Category is the controlled vocabulary doctors reference (feature
// 005-doctor-categories). It is admin-managed and public-readable
// (filtered to ACTIVE rows). Composite unique on (name, status) lets
// a DEACTIVATED row share a name with an ACTIVE row, so re-creation
// under a previously-retired name is possible.
model Category {
  id        String   @id @default(cuid())
  name      String
  status    String   @default("ACTIVE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctors Doctor[]

  @@unique([name, status])
  @@index([status])
  @@map("category")
}

// Doctor is a standalone CRUD record. It has NO foreign key to User.
// Doctors cannot log in; they are managed entirely by admins via the
// /api/admin/doctors endpoints (see feature 003-remove-doctor-role).
// categoryId is required and references an ACTIVE Category (feature
// 005-doctor-categories); the free-text `specialty` column was
// dropped in this migration.
model Doctor {
  id         String   @id @default(cuid())
  name       String
  categoryId String
  bio        String?
  imageUrl   String?
  status     String   @default("ACTIVE")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  slots        DoctorSlot[]
  appointments Appointment[]

  @@index([status])
  @@index([categoryId])
  @@map("doctor")
}

// DoctorSlot is a bookable time window attached to a doctor
// (feature 006-appointments-booking). Lifecycle:
//   AVAILABLE -> BOOKED (patient booking, atomic with appointment create)
//   AVAILABLE -> BLOCKED (admin block, or PATCH status=BLOCKED)
//   BOOKED -> AVAILABLE (appointment cancellation, atomic with the
//     appointment update)
// One slot can result in at most one appointment (enforced by the
// UNIQUE constraint on Appointment.slotId).
model DoctorSlot {
  id        String   @id @default(cuid())
  doctorId  String
  startsAt  DateTime
  endsAt    DateTime
  status    String   @default("AVAILABLE")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  appointment Appointment?

  @@index([doctorId, startsAt])
  @@index([status])
  @@map("doctor_slot")
}

// Appointment is a patient's claim on a doctor slot. Lifecycle:
//   PENDING (on booking) -> CONFIRMED (admin confirms)
//   PENDING -> CANCELLED (patient or admin cancels)
//   CONFIRMED -> CANCELLED (patient <= 24h cutoff, or admin any time)
//   CONFIRMED -> COMPLETED (admin completes, requires scheduledAt in
//     the past)
// Terminal states: COMPLETED and CANCELLED are immutable.
// UNIQUE on slotId enforces 1:1 with the slot at the DB level; the
// application's prisma.$transaction with a conditional updateMany is
// the application-level concurrency guard.
model Appointment {
  id           String    @id @default(cuid())
  userId       String
  doctorId     String
  slotId       String    @unique
  scheduledAt  DateTime
  status       String    @default("PENDING")
  patientNotes String?
  adminNotes   String?
  cancelledAt  DateTime?
  cancelledBy  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user   User       @relation(fields: [userId], references: [id], onDelete: Restrict)
  doctor Doctor     @relation(fields: [doctorId], references: [id], onDelete: Restrict)
  slot   DoctorSlot @relation(fields: [slotId], references: [id], onDelete: Restrict)

  @@index([userId, scheduledAt])
  @@index([doctorId, scheduledAt])
  @@index([status])
  @@map("appointment")
}

# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vezeta_auth?schema=public"

# CORS — REQUIRED in production. Comma-separated list of allowed origins.
# Leave unset in dev to allow any origin (credentials still sent).
# Example: CORS_ORIGIN="https://app.vezeta.com,https://admin.vezeta.com"
CORS_ORIGIN=

# Swagger UI — leave enabled in dev, disable in production.
# Set SWAGGER_ENABLED=false to hide /api/docs and /api/docs-json in prod.
# Defaults to: enabled when NODE_ENV != "production", disabled otherwise.
SWAGGER_ENABLED=true

# Better Auth — REQUIRED. Generate with: openssl rand -base64 32
# Must be >= 32 random characters; the committed dev placeholder is rejected at boot.
BETTER_AUTH_SECRET="generate-with-openssl-rand-base64-32"
BETTER_AUTH_URL="http://localhost:3000"

# Email provider (Resend) — https://resend.com/api-keys
# Sign up at https://resend.com, create an API key, and paste it below.
# For local development, keep EMAIL_FROM set to the Resend sandbox sender —
# this lets you send OTPs without verifying a custom domain. The sandbox is
# limited to delivering to addresses you control (or to Resend's reserved
# test mailboxes listed under RESEND_TEST_INBOX).
RESEND_API_KEY=""
EMAIL_FROM="Vezeeta <onboarding@resend.dev>"

# Reserved Resend test mailboxes (always deliverable, no domain verification):
#   delivered@resend.dev   → 2xx success
#   bounced@resend.dev     → hard bounce simulation
#   complained@resend.dev  → spam complaint simulation
# Set this to whichever mailbox you want `npm run test:email` to target.
RESEND_TEST_INBOX="delivered@resend.dev"

# SMS provider
SMS_PROVIDER_API_KEY=""
SMS_PROVIDER_SENDER_ID="Vezeeta"

# Super Admin seed
# IMPORTANT: override the default password before any non-dev deploy.
SEED_ADMIN_EMAIL="admin@vezeta.local"
SEED_ADMIN_PHONE="+201000000000"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="Super Admin"

# Social login — Google (OAuth client from Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Social login — Facebook (App id + secret from Facebook Developer Dashboard)
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

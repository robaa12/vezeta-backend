                { "key": "page", "value": "1", "description": "1-based page number." },
                { "key": "pageSize", "value": "5", "description": "Items per page (1-100)." }
              ]
            },
            "description": "Pagination example. `pageSize` is capped at 100; values >100 return 400."
          }
        },
        {
          "name": "Get Doctor by id (public profile)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/doctors/{{doctorId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors", "{{doctorId}}"]
            },
            "description": "Public doctor profile. 200 for ACTIVE doctors, 404 for DEACTIVATED or non-existent ids (the two cases are indistinguishable to prevent information leakage). No auth required."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('returns 200 or 404', () => pm.expect([200, 404]).to.include(pm.response.code));",
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.test('doctor has id, name, specialty', () => {",
                  "    pm.expect(body.doctor).to.have.property('id');",
                  "    pm.expect(body.doctor).to.have.property('name');",
                  "    pm.expect(body.doctor).to.have.property('specialty');",
                  "  });",
                  "  pm.test('status is ACTIVE', () => pm.expect(body.doctor.status).to.eql('ACTIVE'));",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get Doctor — non-existent (404)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }

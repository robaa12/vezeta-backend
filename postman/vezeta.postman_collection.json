              "raw": "{{baseUrl}}/api/doctors?search=Smith",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors"],
              "query": [
                { "key": "search", "value": "Smith", "description": "Case-insensitive substring on name + specialty." }
              ]
            },
            "description": "Search the listing by a substring. Case-insensitive. Matches against both `name` and `specialty`."
          }
        },
        {
          "name": "List Doctors (specialty + search combined)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/doctors?specialty=Cardiology&search=Jane",
              "host": ["{{baseUrl}}"],
              "path": ["api", "doctors"],
              "query": [
                { "key": "specialty", "value": "Cardiology" },
                { "key": "search", "value": "Jane" }
              ]
            },
            "description": "Combined filter. Both conditions must match (AND)."
          }
        },
